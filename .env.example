# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
RECEIPT_PROGRAM_ID=YourAnchorProgramIdHere
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# ── LI.FI ─────────────────────────────────────────────────────────────────────
LIFI_API_KEY=YOUR_LIFI_KEY

# ── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_KEY
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ── LLM (intents avanzados) ───────────────────────────────────────────────────
LLM_API_KEY=YOUR_LLM_KEY

# ── Base de datos (Neon PostgreSQL en Vercel) ─────────────────────────────────
# En Vercel: Settings → Storage → Neon → Connect
# Copia el valor de DATABASE_URL que genera Vercel/Neon
DATABASE_URL=postgres://user:pass@host.neon.tech/vibebroker?sslmode=require

# ── Política de voz ───────────────────────────────────────────────────────────
VOICE_CONFIDENCE_MIN=0.8
VOICE_ONLY_MAX_PER_OP=0.1
VOICE_ONLY_DAILY_CAP=0.5
SESSION_KEYS_ALLOWED=false
