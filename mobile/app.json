{
  "expo": {
    "name": "Vibe Broker",
    "slug": "vibe-broker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#05050f"
    },
    "scheme": "vibebroker",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vibebroker.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Vibe Broker necesita acceso al micrófono para comandos de voz",
        "NSMicrophoneUsageDescription": "Vibe Broker usa el micrófono para reconocer tus comandos DeFi"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#05050f"
      },
      "package": "com.vibebroker.app",
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-router",
      "@react-native-voice/voice",
      [
        "expo-av",
        { "microphonePermission": "Vibe Broker usa el micrófono para comandos de voz" }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": { "projectId": "vibe-broker-001" }
    }
  }
}
