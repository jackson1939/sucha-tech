{
  "cli": { "version": ">= 10.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "API_BASE_URL": "https://sucha-tech.vercel.app"
      }
    },
    "production": {
      "android": { "buildType": "app-bundle" },
      "env": {
        "API_BASE_URL": "https://sucha-tech.vercel.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
