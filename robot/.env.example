PICOVOICE_KEY=your_picovoice_access_key
API_BASE_URL=http://localhost:3000
# Porcupine free tier solo soporta keywords built-in (ej: "porcupine", "alexa").
# Para usar "Hey Broker": crea un keyword custom en console.picovoice.ai
